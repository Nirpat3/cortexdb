# ============================================================
# CortexDB — Staging Environment Configuration
# Copy to .env.staging and fill ALL values before deploying
#
# This is a PRE-PRODUCTION environment. It mirrors production
# security requirements (no default secrets) but allows direct
# port access for debugging and testing.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml \
#     --env-file .env.staging up -d
# ============================================================

# -------------------------------------------------------
# REQUIRED — Deployment will fail without these
# -------------------------------------------------------

# Environment mode (must be "staging")
CORTEX_ENV=staging

# Security keys — generate with: openssl rand -hex 32
# These can be simpler than production but MUST be set
CORTEX_SECRET_KEY=
CORTEX_ADMIN_TOKEN=
CORTEX_MASTER_KEY=

# SuperAdmin passphrase
CORTEXDB_MASTER_SECRET=

# Database passwords — generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
REDIS_PASSWORD=
STREAM_PASSWORD=

# CORS — staging origins
CORTEX_CORS_ORIGINS=http://localhost:3400,http://staging.cortexdb.example.com

# Dashboard API URL — staging endpoint
NEXT_PUBLIC_API_URL=http://localhost:5400

# Grafana admin password
GRAFANA_PASSWORD=

# -------------------------------------------------------
# LLM Providers — at least one required for agent features
# -------------------------------------------------------

# Ollama (recommended: self-hosted, no API costs)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# -------------------------------------------------------
# Optional — Observability & Metrics
# -------------------------------------------------------

# Health metrics auth token
CORTEX_METRICS_TOKEN=

# Log format (json recommended)
LOG_FORMAT=json

# -------------------------------------------------------
# Optional — Ports (only change if you have port conflicts)
# -------------------------------------------------------

# Dashboard port (exposed directly, no Nginx in staging)
DASHBOARD_PORT=3400
