# CortexDB Environment Configuration
# Copy to .env and customize

# Secret key (CHANGE THIS in production - use: openssl rand -hex 32)
CORTEX_SECRET_KEY=change-this-in-production-use-64-char-random

# Data storage path (Synology: /volume1/docker/cortexdb/data)
CORTEX_DATA_PATH=./data

# Engine passwords (CHANGE THESE in production)
# POSTGRES_PASSWORD=cortex_secret
# REDIS_PASSWORD=cortex_redis_secret
# STREAM_PASSWORD=cortex_stream_secret
