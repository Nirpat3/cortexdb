# CortexDB Environment Configuration
# Copy to .env and fill in production values
# NEVER commit .env to version control

# ── Required (generate with: openssl rand -hex 32) ──
CORTEX_SECRET_KEY=GENERATE-64-CHAR-RANDOM-STRING
CORTEX_MASTER_KEY=GENERATE-64-CHAR-RANDOM-STRING

# ── Admin Access ──
CORTEX_ADMIN_TOKEN=GENERATE-64-CHAR-RANDOM-STRING

# ── Database Passwords (CHANGE ALL in production) ──
POSTGRES_PASSWORD=cortex_secret
REDIS_PASSWORD=cortex_redis_secret
STREAM_PASSWORD=cortex_stream_secret

# ── Data Storage ──
CORTEX_DATA_PATH=./data

# ── CORS (comma-separated allowed origins) ──
CORTEX_CORS_ORIGINS=http://localhost:3000,http://localhost:5400

# ── Generate all secrets at once: ──
# for i in 1 2 3 4 5; do openssl rand -hex 32; done
# python -c "import secrets; [print(secrets.token_hex(32)) for _ in range(5)]"
