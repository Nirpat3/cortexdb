# ============================================================
# CortexDB Environment Configuration
# Copy to .env and fill in your values
#
# For development: copy as-is, defaults work out of the box
# For production:  use ./scripts/generate-secrets.sh instead
# ============================================================

# Environment: development | production
CORTEX_ENV=development

# Domain (production only — used for CORS, TLS, dashboard URL)
# CORTEX_DOMAIN=cortexdb.example.com

# Security (REQUIRED — generate with: openssl rand -hex 32)
CORTEX_SECRET_KEY=
CORTEX_ADMIN_TOKEN=
CORTEX_MASTER_KEY=

# SuperAdmin passphrase
CORTEXDB_MASTER_SECRET=

# Database passwords (generate with: openssl rand -hex 16)
POSTGRES_PASSWORD=cortex_secret
REDIS_PASSWORD=cortex_redis_secret
STREAM_PASSWORD=cortex_stream_secret

# Dashboard API URL (where the dashboard sends API requests)
# Development: http://localhost:5400  |  Production: https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5400

# CORS origins (comma-separated)
CORTEX_CORS_ORIGINS=http://localhost:3000,http://localhost:3400,http://localhost:5400

# LLM Providers (at least one required for agent features)
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ports
DASHBOARD_PORT=3400

# Observability (optional)
GRAFANA_PASSWORD=cortex_admin
CORTEX_METRICS_TOKEN=
LOG_FORMAT=json
