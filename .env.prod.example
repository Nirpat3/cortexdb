# ============================================================
# CortexDB — Production Environment Configuration
# Copy to .env and fill ALL values before deploying
# ============================================================

# -------------------------------------------------------
# REQUIRED — Deployment will fail without these
# -------------------------------------------------------

# Domain (used for CORS, TLS, Grafana root URL)
CORTEX_DOMAIN=cortexdb.example.com

# Environment mode
CORTEX_ENV=production

# Security keys — generate with: openssl rand -hex 32
CORTEX_SECRET_KEY=
CORTEX_ADMIN_TOKEN=
CORTEX_MASTER_KEY=

# SuperAdmin passphrase
CORTEXDB_MASTER_SECRET=

# Database passwords — generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
REDIS_PASSWORD=
STREAM_PASSWORD=

# CORS — your production domain(s), comma-separated
CORTEX_CORS_ORIGINS=https://cortexdb.example.com

# Dashboard API URL — must match your public domain
NEXT_PUBLIC_API_URL=https://cortexdb.example.com

# Grafana admin password
GRAFANA_PASSWORD=

# -------------------------------------------------------
# LLM Providers — at least one required for agent features
# -------------------------------------------------------

# Ollama (recommended: self-hosted, no API costs)
# If running on same host: http://host.docker.internal:11434
# If running in Docker network: http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# -------------------------------------------------------
# Optional — Observability & Metrics
# -------------------------------------------------------

# Health metrics auth token
CORTEX_METRICS_TOKEN=

# Log format (json recommended for production)
LOG_FORMAT=json

# -------------------------------------------------------
# Optional — Ports (only change if you have port conflicts)
# -------------------------------------------------------

# Dashboard internal port (Nginx proxies to this)
DASHBOARD_PORT=3000
