          "refId": "A",
          "expr": "sum(rate(node_disk_read_bytes_total{device=~\"sd.*|nvme.*\"}[5m]))",
          "legendFormat": "Disk Read"
        },
        {
          "refId": "B",
          "expr": "sum(rate(node_disk_written_bytes_total{device=~\"sd.*|nvme.*\"}[5m]))",
          "legendFormat": "Disk Write"
        }
      ]
